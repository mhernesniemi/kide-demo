---
import { parseList } from "@/cms/core/content";
import { cmsImage, cmsSrcset } from "@/cms/core/image";

const { images: rawImages } = Astro.props;
const images = parseList<string>(rawImages);
---

{
  images.length > 0 && (
    <section>
      <div class="grid gap-4">
        {images.map((src) => (
          <img
            src={src.startsWith("/uploads/") ? cmsImage(src, 1024) : src}
            srcset={src.startsWith("/uploads/") ? cmsSrcset(src) : undefined}
            sizes={src.startsWith("/uploads/") ? "(max-width: 768px) 100vw, 768px" : undefined}
            alt=""
            loading="lazy"
            class="h-auto w-full rounded-lg object-cover"
          />
        ))}
      </div>
    </section>
  )
}
