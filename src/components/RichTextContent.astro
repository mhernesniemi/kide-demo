---
import { renderRichText } from "../cms/core/richtext";

const { content, className } = Astro.props;
const parsed =
  typeof content === "string"
    ? (() => {
        try {
          return JSON.parse(content);
        } catch {
          return null;
        }
      })()
    : content;
const html = renderRichText(parsed);
---

{html && <div class:list={["prose", className]} set:html={html} />}
